    {
      "description": "Update object label",
      "fullName": "Update object label",
      "functionType": "Action",
      "group": "Labels 3D",
      "name": "UpdateObjectLabel",
      "sentence": "Update _PARAM1_ label position with sticky edges _PARAM2_, rotate with object _PARAM3_, smoothness _PARAM4_, ID _PARAM5_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::JsCode",
          "inlineCode": [
            "if (!gdjs._3dLabels) return;",
            "const layer = runtimeScene.getLayer(\"\");",
            "const camera = layer.getRenderer().getThreeCamera();",
            "const canvas = runtimeScene.getGame().getRenderer().getCanvas();",
            "const rect = canvas.getBoundingClientRect();",
            "const id = eventsFunctionContext.getArgument(\"ID\");",
            "const stickyEdges = eventsFunctionContext.getArgument(\"StickyEdges\");",
            "const rotatewithobject = eventsFunctionContext.getArgument(\"Rotation\");",
            "objects.forEach((obj) => {",
            "    const key = obj.id + \"_\" + id;",
            "    const label = gdjs._3dLabels.get(key);",
            "    if (!label) return;",
            "    const threeObj = obj.get3DRendererObject();",
            "    if (!threeObj) return;",
            "    let vector;",
            "    if (rotatewithobject) {",
            "        const localOffset = new THREE.Vector3(",
            "            label._xoffset/20 || 0,",
            "            (label._yoffset/20 || 0) + 0.8,",
            "            label._zoffset/20 || 0",
            "        );",
            "        vector = threeObj.localToWorld(localOffset);",
            "    } else {",
            "        vector = new THREE.Vector3();",
            "        threeObj.getWorldPosition(vector);",
            "        vector.x += label._xoffset || 0;",
            "        vector.y += (label._yoffset || 0) + 0.8;",
            "        vector.z += label._zoffset || 0;",
            "    }",
            "    const dist = camera.position.distanceTo(vector);",
            "    vector.project(camera);",
            "    const margin = 0.95;",
            "    if (!stickyEdges) {",
            "        if (vector.z > 1) {",
            "            label.style.display = \"none\";",
            "            return;",
            "        }",
            "        label.style.display = \"block\";",
            "    } else {",
            "        label.style.display = \"block\";",
            "        if (vector.z > 1 || Math.abs(vector.x) > margin || Math.abs(vector.y) > margin) {",
            "            if (vector.z > 1) {",
            "                vector.x = -vector.x;",
            "                vector.y = -vector.y;",
            "            }",
            "            if (Math.abs(vector.x) < 0.01 && Math.abs(vector.y) < 0.01) {",
            "                vector.y = -margin;",
            "            } else {",
            "                const scaleToEdge = margin / Math.max(Math.abs(vector.x), Math.abs(vector.y));",
            "                vector.x *= scaleToEdge;",
            "                vector.y *= scaleToEdge;",
            "            }",
            "        }",
            "    }",
            "    const targetX = (vector.x * 0.5 + 0.5) * rect.width + rect.left;",
            "    const targetY = (-vector.y * 0.5 + 0.5) * rect.height + rect.top;",
            "    if (label._px === undefined) {",
            "",
            "        label._px = targetX;",
            "        label._py = targetY;",
            "",
            "    }",
            "    const smooth = eventsFunctionContext.getArgument(\"Smooth\");",
            "    label._px += (targetX - label._px) * smooth;",
            "    label._py += (targetY - label._py) * smooth;",
            "    label.style.left = Math.round(label._px) + \"px\";",
            "    label.style.top = Math.round(label._py) + \"px\";",
            "    const size = label._size || 1;",
            "    const scale = Math.max(size, Math.min(1.5, 10 / (dist / 10 + 1)));",
            "    label.style.transform = `translate(-50%, -50%) scale(${scale})`;",
            "    const img = label.querySelector(\"img\");",
            "    if (img) {",
            "        img.style.transform = \"translateZ(0)\";",
            "}",
            "});"
          ],
          "parameterObjects": "Object",
          "useStrict": true,
          "eventsSheetExpanded": true
        }
      ],
      "parameters": [
        {
          "description": "3D Object",
          "name": "Object",
          "type": "objectList"
        },
        {
          "defaultValue": "False",
          "description": "Sticky edges",
          "name": "StickyEdges",
          "optional": true,
          "type": "trueorfalse"
        },
        {
          "description": "Rotate lable with object",
          "name": "Rotation",

    {
      "description": "Update label position by ID",
      "fullName": "Update label position by ID",
      "functionType": "Action",
      "name": "UpdateLabel",
      "sentence": "Update label position with sticky edges _PARAM1_, smoothness _PARAM2_, ID _PARAM3_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::JsCode",
          "inlineCode": [
            "const labelId = eventsFunctionContext.getArgument(\"ID\");",
            "const stickyEdges = eventsFunctionContext.getArgument(\"StickyEdges\");",
            "const maxDistance = 1000000;",
            "const layer = runtimeScene.getLayer(\"\");",
            "const camera = layer.getRenderer().getThreeCamera();",
            "const canvas = runtimeScene.getGame().getRenderer().getCanvas();",
            "const rect = canvas.getBoundingClientRect();",
            "const currentTime = Date.now();",
            "if (!gdjs._3dLabels) return;",
            "const label = gdjs._3dLabels.get(labelId);",
            "if (!label) return;",
            "label._lastActive = currentTime;",
            "const x = label._pos.x;",
            "const y = label._pos.y;",
            "const z = label._pos.z;",
            "if (!gdjs._tempVec3) gdjs._tempVec3 = new THREE.Vector3();",
            "const vector = gdjs._tempVec3;",
            "vector.set(x, y, z);",
            "const dist = camera.position.distanceTo(vector);",
            "if (dist > maxDistance) {",
            "    label.style.display = \"none\";",
            "} else {",
            "    vector.project(camera);",
            "    if (!stickyEdges && vector.z > 1) {",
            "        label.style.display = \"none\";",
            "        return;",
            "    }",
            "    label.style.display = \"block\";",
            "    const margin = 0.95;",
            "    if (stickyEdges && (vector.z > 1 || Math.abs(vector.x) > margin || Math.abs(vector.y) > margin)) {",
            "        if (vector.z > 1) {",
            "            vector.x = -vector.x;",
            "            vector.y = -vector.y;",
            "        }",
            "        if (Math.abs(vector.x) < 0.01 && Math.abs(vector.y) < 0.01) {",
            "            vector.y = -margin;",
            "        } else {",
            "            const scaleToEdge = margin / Math.max(Math.abs(vector.x), Math.abs(vector.y));",
            "            vector.x *= scaleToEdge;",
            "            vector.y *= scaleToEdge;",
            "        }",
            "    }",
            "    const targetX = (vector.x * 0.5 + 0.5) * rect.width + rect.left;",
            "    const targetY = (-vector.y * 0.5 + 0.5) * rect.height + rect.top;",
            "    if (label._px === undefined) label._px = targetX;",
            "    if (label._py === undefined) label._py = targetY;",
            "    const smooth = eventsFunctionContext.getArgument(\"Smooth\");",
            "    label._px += (targetX - label._px) * smooth;",
            "    label._py += (targetY - label._py) * smooth;",
            "    label.style.left = Math.round(label._px) + \"px\";",
            "    label.style.top = Math.round(label._py) + \"px\";",
            "    const size = label._size || 1;",
            "    const scale = Math.max(size, Math.min(1.5, 10 / (dist / 10 + 1)));",
            "    label.style.transform = `translate(-50%, -50%) scale(${scale})`;",
            "    const img = label.querySelector(\"img\");",
            "    if (img) {",
            "        img.style.transform = \"translateZ(0)\";",
            "    }",
            "}"
          ],
          "parameterObjects": "",
          "useStrict": true,
          "eventsSheetExpanded": true
        }
      ],
      "parameters": [
        {
          "description": "Sticky edges",
          "name": "StickyEdges",
          "type": "trueorfalse"
        },
        {
          "description": "Smoothness of label movement (0–1)",
          "name": "Smooth",
          "type": "expression"
        },
        {
          "description": "ID (Integer number)",
          "name": "ID",
          "type": "expression"
        }
      ],

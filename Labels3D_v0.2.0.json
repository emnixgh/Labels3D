    {
      "description": "Create label at object",
      "fullName": "Create label at object",
      "functionType": "Action",
      "group": "Labels 3D",
      "name": "CreateLabelAtObject",
      "sentence": "Create label at _PARAM1_ with font _PARAM2_, text _PARAM3_, align _PARAM4_, image _PARAM5_ size _PARAM6_, color _PARAM7_, shadow _PARAM8_, color shadow _PARAM9_, X offset _PARAM10_, Y offset _PARAM11_, Z offset _PARAM12_, ID _PARAM13_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::JsCode",
          "inlineCode": [
            "if (objects.length === 0) return;",
            "if (!gdjs._3dLabels) gdjs._3dLabels = new Map();",
            "const text = eventsFunctionContext.getArgument(\"Text\");",
            "const colorArg = eventsFunctionContext.getArgument(\"Color\");",
            "const shadowColorArg = eventsFunctionContext.getArgument(\"ShadowColor\");",
            "const size = eventsFunctionContext.getArgument(\"Size\");",
            "const id = eventsFunctionContext.getArgument(\"ID\");",
            "const align = eventsFunctionContext.getArgument(\"Align\");",
            "const shadow = eventsFunctionContext.getArgument(\"Shadow\");",
            "const font = eventsFunctionContext.getArgument(\"Font\");",
            "const xoffset = eventsFunctionContext.getArgument(\"X\");",
            "const yoffset = eventsFunctionContext.getArgument(\"Y\");",
            "const zoffset = eventsFunctionContext.getArgument(\"Z\");",
            "const LabelTexture = eventsFunctionContext.getArgument(\"LabelTexture\");",
            "let color = \"white\";",
            "let shadowColor = \"black\";",
            "if (colorArg) {",
            "    const rgb = colorArg.split(\";\").map(Number);",
            "    if (rgb.length === 3) {",
            "        color = `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;",
            "    }",
            "}",
            "if (shadowColorArg) {",
            "    const rgb = shadowColorArg.split(\";\").map(Number);",
            "    if (rgb.length === 3) {",
            "        shadowColor = `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;",
            "    }",
            "}",
            "objects.forEach((obj) => {",
            "    const key = obj.id + \"_\" + id;",
            "    if (gdjs._3dLabels.has(key)) return;",
            "    const div = document.createElement(\"div\");",
            "    div.style.position = \"absolute\";",
            "    div.style.pointerEvents = \"none\";",
            "    div.style.color = color;",
            "    div.style.padding = \"3px 8px\";",
            "    div.style.background = \"rgba(0,0,0,0)\";",
            "    div.style.borderRadius = \"4px\";",
            "    div.style.fontFamily = font;",
            "    div.style.fontSize = \"14px\";",
            "    div.style.whiteSpace = \"nowrap\";",
            "    div.style.transform = \"translate(-50%, -50%)\";",
            "    div.style.zIndex = \"1000\";",
            "    div.style.textAlign = align;",
            "    if (shadow) {",
            "        div.style.textShadow = `1px 1px 2px ${shadowColor}`;",
            "    }",
            "    if (LabelTexture) {",
            "        const img = document.createElement(\"img\");",
            "        const texture = runtimeScene",
            "            .getGame()",
            "            .getImageManager()",
            "            .getPIXITexture(LabelTexture);",
            "        if (texture && texture.baseTexture.resource) {",
            "            img.src = texture.baseTexture.resource.url;",
            "        }",
            "        img.style.display = \"block\";",
            "        img.style.pointerEvents = \"none\";",
            "        const baseSize = 64;",
            "        img.style.width = baseSize + \"px\";",
            "        img.style.height = \"auto\";",
            "        img.style.objectFit = \"contain\";",
            "        div.appendChild(img);",
            "    }",
            "    if (text) {",
            "        const span = document.createElement(\"span\");",
            "        span.innerText = text;",
            "        div.appendChild(span);",
            "    }",
            "    div._size = size;",
            "    div._id = id;",
            "    div._xoffset = xoffset;",
            "    div._yoffset = yoffset;",
            "    div._zoffset = zoffset;",
            "    document.body.appendChild(div);",
            "    gdjs._3dLabels.set(key, div);",
            "});"
          ],
          "parameterObjects": "Object",
          "useStrict": true,
          "eventsSheetExpanded": true
        }
      ],

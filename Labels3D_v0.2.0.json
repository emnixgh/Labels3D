      "name": "DeleteObjectLabel",
      "sentence": "Delete _PARAM1_ label with ID _PARAM2_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::JsCode",
          "inlineCode": [
            "if (!gdjs._3dLabels) return;",
            "const id = eventsFunctionContext.getArgument(\"ID\");",
            "objects.forEach((obj) => {",
            "  const key = obj.id + \"_\" + id;",
            "  const label = gdjs._3dLabels.get(key);",
            "  if (!label) return;",
            "  if (label.parentNode) {",
            "    label.parentNode.removeChild(label);",
            "  }",
            "  gdjs._3dLabels.delete(key);",
            "});"
          ],
